    "trace_steps": [
      "fit annualize: 2500 * 26 = 65000",
      "fit table SMS standard, row [57900, 113200): tentative 5800 + 0.22 over 57900",
      "fit tentative: 5800 + 0.22*(65000-57900) = 5800 + 1562 = 7362",
      "fit deannualize: 7362 / 26 = 283.1538... → 283.15",
      "fica_ss: 2500 * 0.062 = 155.00",
      "fica_medicare: 2500 * 0.0145 = 36.25",
      "futa effective rate: 0.006 + 0.003 = 0.009 (CREDIT REDUCTION STATE)",
      "futa remaining base: max(7000 - 0, 0) = 7000",
      "futa taxable: min(2500, 7000) = 2500",
      "futa: 2500 * 0.009 = 22.50"
    ]
  }
