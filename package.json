{
  "name": "paygon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workflow engine for payroll processors at mid-size service bureaus. Stateless cockpit; clients own their data.",
  "repository": {
    "type": "git",
    "url": "https://github.com/giovannigutierrez-sketch/Paygon.git"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.4.3",
    "lucide-react": "^0.460.0",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.5",
    "autoprefixer": "^10.5.0",
    "fast-check": "^3.23.1",
    "postcss": "^8.5.13",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
